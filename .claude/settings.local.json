{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:chromewebstore.google.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.cloud.google.com)",
      "WebFetch(domain:autocontentapi.com)",
      "Bash(npm --version)",
      "Bash(npm install:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vite:*)",
      "Bash(npx vitest:*)",
      "Bash(node -e \":*)",
      "Bash(npx wrangler:*)",
      "mcp__plugin_playwright_playwright__browser_navigate",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:dev.to)",
      "mcp__plugin_playwright_playwright__browser_evaluate",
      "mcp__plugin_playwright_playwright__browser_close",
      "WebFetch(domain:medium.com)",
      "WebFetch(domain:scrapecreators.com)",
      "WebFetch(domain:blog.nidhin.dev)",
      "WebFetch(domain:grokipedia.com)",
      "mcp__plugin_playwright_playwright__browser_snapshot",
      "mcp__plugin_playwright_playwright__browser_click",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "WebFetch(domain:support.google.com)",
      "WebFetch(domain:elephas.app)",
